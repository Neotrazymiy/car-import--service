	"components": {
		"schemas": {
			"ApiError": {
				"type": "object"
			},
			"MakeRequestDto": {
				"required": [
					"name"
				],
				"type": "object",
				"properties": {
					"name": {
						"maxLength": 30,
						"minLength": 3,
						"pattern": "^[A-Z][A-Za-z-]{2,14}(?: [A-Z][A-Za-z-]{2,14})?$",
						"type": "string",
						"description": "Make",
						"example": "Daewoo"
					}
				}
			},
			"CategoryRequestDto": {
				"required": [
					"name"
				],
				"type": "object",
				"properties": {
					"name": {
						"maxLength": 15,
						"minLength": 3,
						"pattern": "^[A-Z][A-Za-z/]{2,14}$",
						"type": "string",
						"description": "Categorys",
						"example": "Sedan"
					}
				}
			},
			"CarRequestDto": {
				"required": [
					"makeName",
					"model",
					"year"
				],
				"type": "object",
				"properties": {
					"model": {
						"maxLength": 60,
						"minLength": 0,
						"pattern": "^[A-Z0-9][A-Za-z0-9-]{0,19}(?: [A-Z0-9][A-Za-z0-9-]{0,19}){0,2}$",
						"type": "string",
						"description": "Car model",
						"example": "Lanos"
					},
					"year": {
						"maximum": 2026,
						"minimum": 1960,
						"type": "integer",
						"description": "Year",
						"format": "int32",
						"example": 2020
					},
					"makeName": {
						"maxLength": 30,
						"minLength": 3,
						"pattern": "^[A-Z][A-Za-z-]{2,14}(?: [A-Z][A-Za-z-]{2,14})?$",
						"type": "string",
						"description": "Make name",
						"example": "Daewoo"
					},
					"categoryName": {
						"maxLength": 60,
						"minLength": 3,
						"pattern": "^[A-Z][A-Za-z\\/,]{2,14}(?: [A-Z][A-Za-z\\/,]{2,14}){0,3}$",
						"type": "string",
						"description": "Category name",
						"example": "Sedan"
					}
				}
			},
			"Pageable": {
				"type": "object",
				"properties": {
