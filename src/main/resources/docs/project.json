				],
				"summary": "Import cars from csv file",
				"operationId": "importCsv",
				"requestBody": {
					"content": {
						"multipart/form-data": {
							"schema": {
								"required": [
									"file"
								],
								"type": "object",
								"properties": {
									"file": {
										"type": "string",
										"format": "binary"
									}
								}
							}
						}
					}
				},
